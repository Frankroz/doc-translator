@page "/login"
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager Nav
@rendermode InteractiveServer 

<PageTitle>Login - Admin</PageTitle>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card p-4 shadow-lg glass-card" style="width: 400px; border: none; background: #1e293b; color: white;">
        <h3 class="text-center mb-4 gradiente-texto fw-bold">Panel Admin</h3>

        @* El formulario ahora debería ser visible *@
        <form method="post" action="api/auth/login">
            <AntiforgeryToken /> 
            
            <div class="mb-3">
                <label class="form-label">Usuario</label>
                <input name="username" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input name="password" type="password" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-2">Entrar</button>
        </form>
    </div>
</div>